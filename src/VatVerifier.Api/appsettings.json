{
  "Ai": {
    "Provider": "Ollama",
    "Ollama": {
      "Endpoint": "http://localhost:11434",
      "EmbeddingModel": "qwen3-embedding:0.6b"
    }
  },
  "Evaluation": {
    "StrongCandidateThreshold": 0.21,
    "AmbiguousCandidateThreshold": 0.20,
    "CandidateMarginThreshold": 0.04,
    "MaxCandidates": 5,
    "ConfidenceThreshold": 0.75,
    "NegativePenaltyWeight": 0.30,
    "DescriptionChannelWeight": 0.70,
    "SupplierChannelWeight": 0.30,
    "RrfK": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "VatVerifier.Api.Evaluation.EmbeddingVatEvaluationEngine": "Information",
      "VatVerifier.Api.Evaluation.Pipeline.EmbeddingClassificationStep": "Debug"
    }
  }
}
